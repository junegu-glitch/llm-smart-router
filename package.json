{
  "name": "llm-smart-router",
  "version": "0.1.0",
  "description": "Multi-model AI agent team orchestrator — route tasks to the best LLM and run parallel agent teams",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cli": "tsc -p tsconfig.cli.json && node scripts/fix-esm-imports.mjs && chmod +x dist/cli/index.js",
    "start": "next start",
    "lint": "eslint",
    "cli": "tsx src/cli/index.ts",
    "cli:interactive": "tsx src/cli/index.ts --interactive",
    "team": "tsx src/cli/index.ts team",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build:cli"
  },
  "bin": {
    "smart-router": "./dist/cli/index.js"
  },
  "files": [
    "dist/cli/**",
    "dist/lib/**",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "llm",
    "ai",
    "router",
    "multi-model",
    "agent",
    "team",
    "cli",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "deepseek",
    "gpt",
    "cost-optimization"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/junegu-glitch/llm-smart-router.git"
  },
  "homepage": "https://github.com/junegu-glitch/llm-smart-router",
  "bugs": {
    "url": "https://github.com/junegu-glitch/llm-smart-router/issues"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "lucide-react": "^0.577.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "next": "16.2.0",
    "ora": "^9.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
